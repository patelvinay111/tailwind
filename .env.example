# ---- Copy this file to .env and fill in real values on-site ----
# cp .env.example .env

# ---------------------------------------------------------------------------
# Vocal Bridge (outbound voice call)
# Fill these in from the hackathon Vocal Bridge dashboard.
# ---------------------------------------------------------------------------
VOCALBRIDGE_API_KEY=vb_xxxxxxxxxxxxxxxxxxxxxxxx
VOCALBRIDGE_BASE_URL=https://api.vocalbridge.ai
VOCALBRIDGE_AGENT_ID=
# The phone number the agent will CALL (yours, for the demo). E.164 format.
DEMO_USER_PHONE=+15551234567
# Public URL Vocal Bridge should hit for webhooks. Use ngrok during the demo:
#   ngrok http 8787  ->  https://<something>.ngrok.app
PUBLIC_BASE_URL=https://your-ngrok-subdomain.ngrok.app

# ---------------------------------------------------------------------------
# Sabre APIs (flight search + booking). Credentials distributed on-site.
# Use the CERT / test environment, not production.
# ---------------------------------------------------------------------------
SABRE_BASE_URL=https://api.cert.platform.sabre.com
# Bearer token from the hackathon Sabre dashboard — used directly (Authorization: Bearer).
SABRE_ACCESS_TOKEN=
# PCC / IPCC — only needed if you enable real booking (SABRE_BOOKING_ENABLED=true).
SABRE_PCC=

# ---------------------------------------------------------------------------
# Demo behavior
# ---------------------------------------------------------------------------
# Global demo switch for Vocal Bridge. When true, calls are faked so the loop
# runs offline. Sabre is controlled separately by SABRE_LIVE below, so you can
# run REAL flight search while voice stays in demo.
DEMO_MODE=true

# Real Sabre SEARCH (InstaFlights/BFM). Needs SABRE_ACCESS_TOKEN set above.
# true = live flight data; false = canned demo flights.
SABRE_LIVE=false

# Real Sabre BOOKING (Create PNR / ticketing). Keep FALSE for the demo — bookings
# are simulated (a fake confirmation number, no real reservation in CERT).
# Only set true if you genuinely intend to create a booking.
SABRE_BOOKING_ENABLED=false
