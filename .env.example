# ===========================================================================
# Tailwind AI — Environment Configuration
# Deploy on EC2: ./deploy.sh
# ===========================================================================

# ---------------------------------------------------------------------------
# Vocal Bridge — THE BRAIN for voice
# VB's AI calls our HTTP tool endpoints directly (EC2 is publicly reachable)
# Setup: vocalbridgeai.com → promo code VBHACKMONTH
# ---------------------------------------------------------------------------
VOCALBRIDGE_API_KEY=vb_xxxxxxxxxxxxxxxxxxxxxxxx
# Real API host is vocalbridgeai.com/api (api.vocalbridge.ai does NOT resolve).
VOCALBRIDGE_BASE_URL=https://vocalbridgeai.com/api
# Browser WebRTC token endpoint. Account key auth needs X-API-Key + X-Agent-Id.
VOCALBRIDGE_TOKEN_URL=https://vocalbridgeai.com/api/v1/token
VOCALBRIDGE_AGENT_ID=

# Your phone number for outbound call demo (optional). E.164 format.
DEMO_USER_PHONE=+15551234567
# Public URL Vocal Bridge must reach for the tool endpoints (/agent/* and /api/*).
# On EC2 this is the public IP/domain; locally use a tunnel. Point the VB agent's
# tool URLs at this too.
PUBLIC_BASE_URL=http://<ec2-public-ip>:8787

# ---------------------------------------------------------------------------
# Sabre APIs — travel data
# Sign up: developer.sabre.com (use hackathon email)
# Access: developer.sabre.com/product-collection/hackathon-2026
# ---------------------------------------------------------------------------
SABRE_BASE_URL=https://api.cert.platform.sabre.com
SABRE_CLIENT_ID=
SABRE_CLIENT_SECRET=
SABRE_ACCESS_TOKEN=
SABRE_PCC=

# ---------------------------------------------------------------------------
# Claude — text-mode fallback (NOT used for voice)
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLAUDE_MODEL=claude-sonnet-4-20250514

# ---------------------------------------------------------------------------
# Demo behavior
# ---------------------------------------------------------------------------
# Set false once VB + Sabre credentials are in place
DEMO_MODE=true

# Real Sabre search (needs SABRE_ACCESS_TOKEN)
SABRE_LIVE=false

# Real Sabre booking (creates actual reservations — keep false for demo)
SABRE_BOOKING_ENABLED=false
