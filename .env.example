# ---- Copy this file to .env and fill in real values on-site ----
# cp .env.example .env

# ---------------------------------------------------------------------------
# Anthropic / Claude (agent brain: what to say + which flight to pick)
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLAUDE_MODEL=claude-opus-4-8

# ---------------------------------------------------------------------------
# Vocal Bridge (outbound voice call)
# Fill these in from the hackathon Vocal Bridge dashboard.
# ---------------------------------------------------------------------------
VOCALBRIDGE_API_KEY=vb_xxxxxxxxxxxxxxxxxxxxxxxx
VOCALBRIDGE_BASE_URL=https://api.vocalbridge.ai
VOCALBRIDGE_AGENT_ID=
# The phone number the agent will CALL (yours, for the demo). E.164 format.
DEMO_USER_PHONE=+15551234567
# Public URL Vocal Bridge should hit for webhooks. Use ngrok during the demo:
#   ngrok http 8787  ->  https://<something>.ngrok.app
PUBLIC_BASE_URL=https://your-ngrok-subdomain.ngrok.app

# ---------------------------------------------------------------------------
# Sabre APIs (flight search + booking). Credentials distributed on-site.
# Use the CERT / test environment, not production.
# ---------------------------------------------------------------------------
SABRE_BASE_URL=https://api.cert.platform.sabre.com
SABRE_CLIENT_ID=
SABRE_CLIENT_SECRET=
# Optional: if the hackathon gives you a pre-minted bearer token instead of
# client id/secret, drop it here and it will be used directly.
SABRE_ACCESS_TOKEN=
# PCC / IPCC used for booking, if provided on-site.
SABRE_PCC=

# ---------------------------------------------------------------------------
# Demo behavior
# ---------------------------------------------------------------------------
# When true, all external calls (Vocal Bridge / Sabre / Claude) are faked so the
# whole loop runs offline. Flip to false once real credentials are in place.
DEMO_MODE=true
